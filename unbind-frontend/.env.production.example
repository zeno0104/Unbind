# 이 파일을 .env.production 으로 복사하고 실제 백엔드 도메인으로 채운 뒤 `npm run build` 하세요.
VITE_API_BASE_URL=https://unbind-api.duckdns.org

# 카카오 애드핏: 홈 화면 광고 단위는 Home.jsx에 직접 하드코딩됨(DAN-sqNwUJ6uhPIBBRke).
# 매듭 숲용 광고 단위는 아직 발급 전 - 발급되면 VITE_ADFIT_UNIT_FOREST 대신 Forest.jsx에도 직접 반영 예정.
VITE_ADFIT_UNIT_FOREST=

# 다짐 리마인더 웹푸시 - 백엔드 application.properties의 vapid.public.key와 반드시 같은 값이어야 함
VITE_VAPID_PUBLIC_KEY=BCEe2YoEfGnIEt6Fgzg1RcZMll_m0KFOrC0XirF_DLyErbEmJe4WNONsU9uRzAww53SheBAB9axcB7gsYKU_5S0

# 매듭 숲 카카오톡 공유하기 - 카카오 디벨로퍼스(developers.kakao.com)에서 JavaScript 키를 발급받아 채워야 함
VITE_KAKAO_JS_KEY=
